sequenceDiagram
    autonumber
    actor U as 用户
    participant F as AccountAddPage / WecomHostingHook
    participant A as channelsApi
    participant R as ChannelHostingRouter
    participant C as IpadClient
    participant S as 真实iPad服务(:9912)
    participant M as MockState
    participant Repo as ChannelMgmtRepository
    participant DB as SQLite

    Note over F: step1 选渠道类型(wecom) → step2 选协议(ipad)

    %% ===== START：init + getQrCode =====
    U->>F: 选 ipad 协议，点「创建账号」
    F->>A: startWecomScan({teamId, name})
    A->>R: POST /api/channels/accounts/wecom/start
    R->>C: start_wecom(team_id, name)
    C->>S: init({deverType:"ipad"})
    alt 真实可达(HTTP 200)
        S-->>C: {uuid, is_login}
        C->>S: getQrCode({uuid})
        S-->>C: {qrcode, qrcode_data, Ttl, Key}
        C-->>R: {uuid, qrcode, qrcode_data, ttl, qrcodeKey, mock:false}
    else 不可达 / 非200 / 超时 → mock 兜底
        C->>M: 生成 mock uuid + 占位二维码(base64)
        C-->>R: {uuid, qrcode_data(占位), ttl, qrcodeKey, mock:true}
    end
    R-->>A: 归一化 start 响应
    A-->>F: WecomHostStartResp
    F->>F: 进入 step3(qr)，启动轮询(2s)

    %% ===== POLL LOOP：等待扫码(loginType 0→1) =====
    loop 每 2s，直到 loginType>=1 或超时
        F->>A: pollWecomLogin({uuid})
        A->>R: POST /api/channels/accounts/wecom/poll
        R->>C: poll_wecom(uuid)
        C->>S: GetRunClientInfo({uuid})
        alt 真实
            S-->>C: {loginType, userInfo, longLinkState}
        else mock
            C->>M: 读取状态(未verify → loginType=1)
            M-->>C: {loginType:1, userInfo:null}
        end
        C-->>R: {loginType, userInfo, longLinkState, mock}
        R-->>A: WecomHostPollResp
        A-->>F: 更新步骤状态
    end
    F->>F: loginType==1 → step4(waiting) 自动跳 step5(verify)

    %% ===== VERIFY：CheckCode =====
    U->>F: 输入 6 位验证码
    F->>A: verifyWecomCode({uuid, qrcodeKey, code})
    A->>R: POST /api/channels/accounts/wecom/verify
    R->>C: verify_wecom(uuid, key, code)
    C->>S: CheckCode({uuid, key, code})
    alt 真实返回 "qrcode_not need verify"
        C-->>R: {ok:true, skip:true}
    else 正常 / mock
        C->>M: 标记 verified=true
        C-->>R: {ok:true}
    end
    R-->>A: {ok:true}
    A-->>F: 继续轮询

    %% ===== POLL → loginType==2 → 持久化 =====
    loop 每 2s，直到 loginType==2
        F->>A: pollWecomLogin({uuid})
        A->>R: POST /api/channels/accounts/wecom/poll
        R->>C: poll_wecom(uuid)
        C->>S: GetRunClientInfo({uuid})
        alt mock(已 verified)
            C->>M: 返回 loginType=2 + 合成 userInfo
            M-->>C: {loginType:2, userInfo:{nickname,corpName,...}}
        else 真实
            S-->>C: {loginType:2, userInfo:{...}}
        end
        C-->>R: {loginType:2, userInfo, longLinkState}
        R->>Repo: create_account_with_ipad(wecom, ipad, team_id, name, uuid, userInfo, host_status="hosted")
        Repo->>DB: INSERT channel_accounts(...)
        DB-->>Repo: row
        Repo-->>R: AccountDTO
        R-->>A: {loginType:2, userInfo, account:AccountDTO}
        A-->>F: WecomHostPollResp
    end
    F->>F: step6 done → toast + navigate('/channels/accounts')
