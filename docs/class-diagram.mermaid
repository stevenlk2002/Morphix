classDiagram
    %% ===== 核心数据实体（表） =====
    class Team {
        +id: str (PK)
        +name: str
        +seats_left: int
        +energy_value: int
        +created_at: str
    }

    class ChannelAccount {
        +id: str (PK)
        +channel: str
        +account_name: str
        +status: str
        +bound_bot: str
        +daily_quota: int
        +team_id: str
        +channel_type: str (wecom|wechat|whatsapp|business_whatsapp)
        +protocol: str (e.g. 'ipad')
        +sessions_count: int
        +created_at: str
    }

    class ChannelSeat {
        +channel_account_id: str (PK)
        +seats_left: int
        +online_sessions: int
    }

    class ChannelContact {
        +id: str (PK)
        +account_id: str (FK)
        +channel: str (@微信/@企业微信)
        +channel_type: str
        +name: str
        +nickname: str
        +type: str (customer|internal|customer_group|internal_group)
        +status: str (online|offline)
        +remark: str
        +description: str
        +add_time: str
        +source: str
    }

    class CustomerProfile {
        +id: str (PK)
        +contact_id: str (FK)
        +phone: str
        +email: str
        +company: str
        +position: str
        +region: str
        +age: int
        +birthday: str
        +remark: str
        +add_time: str
        +add_channel: str
        +signature: str
    }

    class CommunicationRecord {
        +id: str (PK)
        +customer_id: str (FK -> CustomerProfile)
        +content: str
        +ai_summary: str
        +type: str
        +created_at: str
    }

    class CustomAttribute {
        +id: str (PK)
        +customer_id: str (FK -> CustomerProfile)
        +name: str
        +value: str
    }

    class ChannelSession {
        +id: str (PK)
        +account_id: str (FK)
        +contact_id: str (FK, nullable)
        +name: str
        +channel: str
        +channel_type: str
        +last_message: str
        +last_time: str
        +unread_count: int
        +read_status: str (read|unread)
        +hosted_status: str (hosted|unhosted)
        +hosted_bot_id: str
        +owner: str
        +online_status: str (online|offline)
        +session_type: str (外部联系人|外部群聊)
        +external_tag: str
        +add_time: str
        +hosting_chain: str
    }

    class HostingSession {
        +id: str (PK)
        +session_key: str (-> ChannelSession.id)
        +account_id: str (FK)
        +customer_name: str
        +customer_remark: str
        +add_time: str
        +hosted_status: str (hosted|unhosted)
        +hosting_chain: str
    }

    class HostingRule {
        +id: str (PK)
        +account_id: str (FK, nullable=全局)
        +auto_resume_seconds: int (nullable)
        +auto_cancel_enabled: int (0|1)
    }

    class WechatSubject {
        +id: str (PK)
        +full_name: str
        +short_name: str
        +corp_id: str
        +config_json: str
    }

    class Message {
        +id: str (PK)
        +conversation_id: str (= ChannelSession.id)
        +sender_type: str (bot|user|system)
        +content: str
        +created_at: str
    }

    %% ===== 服务层 =====
    class ChannelMgmtRepository {
        +list_teams() list
        +list_accounts_enriched() list
        +create_account(channel_type, protocol, team_id, name) dict
        +list_contacts(account_id?, type?, status?, search?) list
        +get_contact_detail(contact_id) dict
        +list_sessions(account_id?, read?, hosted?, online?, search?) list
        +list_session_messages(session_id) list
        +set_session_hosting(session_id, hosted, bot_id) dict
        +list_hosting_sessions(account_id?, bot_id?, session_type?, nickname?, start?, end?) list
        +batch_update_hosting(ids, hosted_status?, hosting_chain?) int
        +get_hosting_rules(account_id?) dict
        +upsert_hosting_rules(...) dict
        +list_wechat_subjects() list
        +create_wechat_subject(...) dict
        +update_wechat_subject(id, ...) dict
        +list_hosting_bots() list
        -row_to_account(row) dict
        -row_to_contact(row) dict
        -row_to_session(row) dict
    }

    class ChannelMgmtRouter {
        +GET /channels/teams
        +GET /channels/accounts
        +POST /channels/accounts
        +GET /channels/contacts
        +GET /channels/contacts/{id}
        +GET /channels/sessions
        +POST /channels/sessions/{id}/hosting
        +GET /channels/hosting-sessions
        +POST /channels/hosting-sessions/batch-update
        +GET/PUT /channels/hosting-rules
        +GET/POST/PUT /channels/wechat-subjects
        +GET /channels/hosting-bots
    }

    %% ===== 关键 DTO =====
    class AccountDTO {
        +id: str
        +name: str
        +channelType: str
        +protocol: str
        +status: str
        +online: bool
        +sessionsCount: int
        +teamId: str
        +boundBot: str
    }
    class ContactDTO {
        +id: str
        +accountId: str
        +name: str
        +channel: str
        +type: str
        +status: str
        +remark: str
        +addTime: str
    }
    class ContactDetailDTO {
        +contact: ContactDTO
        +profile: CustomerProfileDTO
        +communications: CommunicationRecordDTO[]
        +attributes: CustomAttributeDTO[]
    }
    class SessionDTO {
        +id: str
        +accountId: str
        +name: str
        +lastMessage: str
        +unreadCount: int
        +readStatus: str
        +hostedStatus: str
        +hostedBotId: str
        +owner: str
        +onlineStatus: str
        +externalTag: str
    }
    class HostingSessionDTO {
        +id: str
        +accountId: str
        +customerName: str
        +customerRemark: str
        +addTime: str
        +hostedStatus: str
        +hostingChain: str
    }
    class HostingBotDTO {
        +id: str
        +name: str
    }

    %% ===== 关系 =====
    Team "1" *-- "0..*" ChannelAccount : team_id
    ChannelAccount "1" *-- "1" ChannelSeat : channel_account_id
    ChannelAccount "1" *-- "0..*" ChannelContact : account_id
    ChannelAccount "1" *-- "0..*" ChannelSession : account_id
    ChannelAccount "1" *-- "0..*" HostingSession : account_id
    ChannelContact "1" *-- "0..1" CustomerProfile : contact_id
    CustomerProfile "1" *-- "0..*" CommunicationRecord : customer_id
    CustomerProfile "1" *-- "0..*" CustomAttribute : customer_id
    ChannelSession "0..1" *-- "0..1" ChannelContact : contact_id
    ChannelSession "1" *-- "0..*" Message : conversation_id
    HostingSession "0..1" --> "0..1" ChannelSession : session_key
    HostingRule "0..1" --> "0..1" ChannelAccount : account_id

    ChannelMgmtRouter ..> ChannelMgmtRepository : 调用
    ChannelMgmtRepository ..> Team : reads
    ChannelMgmtRepository ..> ChannelAccount : reads
    ChannelMgmtRepository ..> ChannelContact : reads
    ChannelMgmtRepository ..> CustomerProfile : reads
    ChannelMgmtRepository ..> ChannelSession : reads
    ChannelMgmtRepository ..> HostingSession : reads
    ChannelMgmtRepository ..> HostingRule : reads
    ChannelMgmtRepository ..> WechatSubject : reads
    ChannelMgmtRepository ..> Message : reads

    ChannelMgmtRepository ..> AccountDTO : produces
    ChannelMgmtRepository ..> ContactDTO : produces
    ChannelMgmtRepository ..> SessionDTO : produces
    ChannelMgmtRepository ..> HostingSessionDTO : produces
    ContactDetailDTO o-- "1" ContactDTO : contact
    ContactDetailDTO o-- "0..1" CustomerProfile : profile
    ContactDetailDTO o-- "0..*" CommunicationRecord : communications
    ContactDetailDTO o-- "0..*" CustomAttribute : attributes
