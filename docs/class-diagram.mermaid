classDiagram
    %% ===== 后端：iPad 协议客户端（含 mock 兜底） =====
    class IpadConfig {
        +base_url : str
        +mode : str
        +timeout_sec : float
    }
    class MockState {
        +uuid : str
        +verified : bool
    }
    class IpadClient {
        +init() IpadInitResult
        +get_qrcode(uuid) IpadQrResult
        +check_code(uuid, key, code) IpadCheckResult
        +get_run_client_info(uuid) IpadClientInfo
        +start_wecom(team_id, name) dict
        +verify_wecom(uuid, key, code) dict
        +poll_wecom(uuid) dict
        -_call_real(path, payload) dict
    }
    class IpadInitResult {
        +uuid : str
        +is_login : bool
    }
    class IpadQrResult {
        +qrcode : str
        +qrcode_data : str
        +ttl : int
        +qrcode_key : str
    }
    class IpadCheckResult {
        +ok : bool
        +skip : bool
    }
    class IpadClientInfo {
        +loginType : int
        +userInfo : dict
        +longLinkState : str
    }

    IpadClient ..> IpadConfig : reads
    IpadClient ..> MockState : tracks per uuid
    IpadClient ..> IpadInitResult : returns
    IpadClient ..> IpadQrResult : returns
    IpadClient ..> IpadCheckResult : returns
    IpadClient ..> IpadClientInfo : returns

    %% ===== 后端：托管路由 + 仓储 + 请求模型 =====
    class ChannelHostingRouter {
        +POST /start(payload) dict
        +POST /verify(payload) dict
        +POST /poll(payload) dict
    }
    class ChannelMgmtRepository {
        +create_account_with_ipad(channel_type, protocol, team_id, name, ipad_uuid, ipad_user_info, host_status) dict
        +list_accounts_enriched() list
    }
    class WecomHostStartRequest {
        +teamId : str
        +name : str
        +channelType : str
    }
    class WecomHostVerifyRequest {
        +uuid : str
        +qrcodeKey : str
        +code : str
    }
    class WecomHostPollRequest {
        +uuid : str
    }

    ChannelHostingRouter ..> IpadClient : uses
    ChannelHostingRouter ..> ChannelMgmtRepository : persists on login
    ChannelHostingRouter ..> WecomHostStartRequest : consumes
    ChannelHostingRouter ..> WecomHostVerifyRequest : consumes
    ChannelHostingRouter ..> WecomHostPollRequest : consumes
    ChannelMgmtRepository ..> IpadClientInfo : stores userInfo

    %% ===== 前端 =====
    class WecomHostingHook {
        +step : str
        +start(teamId, name) void
        +submitCode(code) void
        +back() void
        -pollLoop() void
    }
    class AccountAddPage {
        +render() JSX
    }
    class ChannelAddSteps {
        +StepType() JSX
        +StepProtocol() JSX
        +StepQr() JSX
        +StepWaiting() JSX
        +StepVerify() JSX
    }
    class ChannelsApi {
        +startWecomScan(data) WecomHostStartResp
        +verifyWecomCode(data) WecomHostVerifyResp
        +pollWecomLogin(data) WecomHostPollResp
    }
    class AccountDTO {
        +id : str
        +name : str
        +channelType : str
        +ipadUuid : str
        +ipadUserInfo : dict
        +hostStatus : str
    }

    AccountAddPage *-- WecomHostingHook : uses
    AccountAddPage *-- ChannelAddSteps : renders
    WecomHostingHook ..> ChannelsApi : calls
    ChannelsApi ..> ChannelHostingRouter : HTTP /api/channels/accounts/wecom/*
    ChannelMgmtRepository ..> AccountDTO : maps via row_to_account
