classDiagram
    %% ---------- 前端组件 / hooks ----------
    class ChannelSessionsPage {
        +selectedAccountId: string|null
        +sessions: SessionDTO[]
        +selectedSessionId: string|null
        +syncStatus: SyncStatusDTO|null
        +activeTab: 'sessions'|'friends'|'groups'
        +lastAutoSyncAt: Record~string,number~
        +handleAutoSync(accountId) void
        +handleCreateGroup(memberIds, roomName) void
        +handleMarkAllRead() void
        +scrollToSession(id) void
    }
    class AccountListPanel {
        +accounts: AccountDTO[]
        +selectedAccountId: string|null
        +onSelect(id) void
    }
    class Resizer {
        +onResizeStart(e) void
    }
    class CreateGroupModal {
        +open: boolean
        +accountId: string
        +friends: ContactDTO[]
        +onClose() void
        +onCreated(group) void
    }
    class useResizablePanels {
        -min: number = 180
        -max: number = 360
        +width: number
        +startDrag(e) void
    }
    class useSessionActions {
        +scrollToTop() void
        +locateUnread() void
        +locateSelected() void
        +markAllRead() void
    }
    class channelsApi {
        +syncAccount(id) SyncResultDTO
        +getSyncStatus(id) SyncStatusDTO
        +listContacts(p) ContactDTO[]
        +createGroup(id, req) GroupDTO
        +markSessionsReadLocal(id, ids?) MarkReadLocalResultDTO
    }

    %% ---------- 后端 ----------
    class iPadSyncRouter {
        +POST /{id}/sync
        +GET /{id}/sync-status
        +POST /{id}/groups
        +POST /{id}/sessions/read-local
    }
    class ipad_sync {
        +trigger_sync(id) bool
        +run_full_sync(id) dict
        +create_group(id, memberIds, roomName) dict
        +mark_sessions_read_local(id, sessionIds) dict
    }
    class ipad_client {
        +create_chatroom(uuid, wxids, roomName) dict
        +mark_as_read(uuid, uid, isRoom) dict
    }
    class ChannelMgmtRepository {
        +mark_session_read_db(sessionId) dict
        +upsert_channel_group(group) void
        +create_session_for_room(accountId, roomId, name, ch, ct) dict
        +get_contact_by_id(id) dict
        +list_groups(accountId, type) list
    }

    %% ---------- 关系 ----------
    ChannelSessionsPage *-- AccountListPanel
    ChannelSessionsPage *-- Resizer
    ChannelSessionsPage *-- CreateGroupModal
    ChannelSessionsPage ..> useResizablePanels : uses
    ChannelSessionsPage ..> useSessionActions : uses
    ChannelSessionsPage ..> channelsApi : calls
    CreateGroupModal ..> channelsApi : listContacts / createGroup
    useSessionActions ..> channelsApi : markSessionsReadLocal
    channelsApi ..> iPadSyncRouter : HTTP
    iPadSyncRouter ..> ipad_sync : invoke
    ipad_sync ..> ipad_client : create_chatroom
    ipad_sync ..> ChannelMgmtRepository : persist
    iPadSyncRouter ..> ChannelMgmtRepository : read/write
    ipad_client ..> ChannelMgmtRepository : (none; protocol only)
